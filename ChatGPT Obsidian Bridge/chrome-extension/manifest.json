{
  "manifest_version": 3,
  "name": "ChatGPT Obsidian Bridge",
  "version": "0.1.0",
  "description": "Selectively import messages from the current ChatGPT conversation into Obsidian.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:28765/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "ChatGPT Obsidian Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "chatgpt-detector.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
